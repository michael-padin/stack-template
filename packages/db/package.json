{
  "name": "@repo/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./seed-data": "./src/seed/example-data.ts"
  },
  "scripts": {
    "generate": "pnpm with-env prisma generate",
    "migrate": "pnpm with-env prisma migrate deploy",
    "migrate:dev": "pnpm with-env prisma migrate dev",
    "push": "pnpm with-env prisma db push",
    "seed": "pnpm with-env tsx src/seed/run.ts",
    "studio": "pnpm with-env prisma studio",
    "typecheck": "tsc --noEmit",
    "with-env": "dotenv -e .env.local --"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@repo/env": "workspace:*",
    "@repo/types": "workspace:*",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "@repo/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "@types/pg": "^8.11.10",
    "dotenv-cli": "^11.0.0",
    "prisma": "^7.8.0",
    "tsx": "^4.22.4",
    "typescript": "catalog:"
  }
}
