# Prisma CLI tooling (generate / migrate / seed). Loaded by `pnpm with-env`
# (dotenv-cli) before scripts run. Apps don't read this file — they use their
# own apps/<app>/.env.local via Next.js's auto-loading.
#
# Local Docker (see docker-compose.yml):
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/app?schema=public
# Hosted (Neon/Supabase/RDS) — use the connection string from your provider:
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
