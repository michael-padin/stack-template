# Prisma CLI tooling (generate / migrate / seed / studio). Loaded via
# dotenv-cli from the ROOT env files, not from this package:
#
#   pnpm db:generate / db:migrate / db:seed / db:studio
#     → reads root .env.local              (packages/db "with-env" script)
#   pnpm db:migrate:staging / db:seed:staging / db:studio:staging
#     → reads root .env.staging            ("with-env:staging")
#   pnpm db:migrate:prod / db:studio:prod
#     → reads root .env.production         ("with-env:prod")
#
# Put DATABASE_URL (and everything else) in the root .env.local — see the
# root .env.example for the full reference and the stage-file notes.
#
# This file exists only so `packages/db` has a documented `.env.example` next
# to its scripts; it isn't read directly by anything.
