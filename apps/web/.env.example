# Public web app (port 3000). Unauthenticated read surface.
# Copy to apps/web/.env.local and fill in. Next.js loads .env.local automatically.

# Postgres connection. OPTIONAL here: when unset, the app falls back to the
# seed dataset (@repo/db/seed-data) so it boots with zero database setup.
# Set it to read real data. Validated at boot via @repo/env/db.
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/app?schema=public

# Display name shown in titles and headers. Defaults to "Internal Tools".
# Validated at boot via @repo/env/client.
NEXT_PUBLIC_APP_NAME=Internal Tools

# Canonical public site URL — used for absolute URLs (OpenGraph, sitemap).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional — admin dashboard URL. When set, the public site shows a
# "Manage" link that opens the admin app.
NEXT_PUBLIC_ADMIN_URL=http://localhost:3001

# Shared secret used to authenticate inbound POSTs to /api/revalidate from
# the admin app. MUST match the value in apps/admin/.env.local. Optional —
# leave unset to disable cross-app revalidation. ≥ 16 chars.
# Generate with `openssl rand -base64 32`. Validated via @repo/env/revalidate.
REVALIDATE_SECRET=

# Optional — Sentry error reporting. Unset = no-op (zero runtime cost).
NEXT_PUBLIC_SENTRY_DSN=

# Optional — public base URL for stored images (extends the next.config
# image allow-list). Set only when @repo/storage is in use.
NEXT_PUBLIC_R2_PUBLIC_URL=
