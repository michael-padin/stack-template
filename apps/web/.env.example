# Public web app (port 3000). Shared vars come from the root .env.example →
# root .env.local; this app has no required per-app overrides, so
# apps/web/.env.local is OPTIONAL (a fresh clone with no env files still
# boots via the seed dataset). Copy this file to apps/web/.env.local only if
# you need an app-local override.

# Example override — uncomment to point this app at a database different
# from the shared root value (rare; most projects never need this).
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/app?schema=public
