# Admin dashboard (port 3001). Sign-in required; the whole app is admin-only.
# Copy to apps/admin/.env.local and fill in. Next.js loads .env.local automatically.

# Postgres connection. REQUIRED — the admin app reads the DB and stores
# sessions there. Use the same database as apps/web.
# Validated at boot via @repo/env/db.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/app?schema=public

# Better Auth secret. ≥ 32 chars. MUST match apps/web's value (sessions are
# DB-backed but the cookie is signed with this secret).
# Generate with `openssl rand -base64 32`. Validated via @repo/env/auth.
BETTER_AUTH_SECRET=replace-with-32-bytes-of-randomness

# Canonical URL of THIS app — used for OAuth callbacks.
BETTER_AUTH_URL=http://localhost:3001

# Optional Google OAuth (omit both to hide the Google sign-in button).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Display name shown in titles, sign-in, and auth. Defaults to "Internal Tools".
# Validated at boot via @repo/env/client.
NEXT_PUBLIC_APP_NAME=Internal Tools

# Shared secret used by admin Server Actions to authenticate POSTs to the
# public web's /api/revalidate route. MUST match apps/web's value. Optional —
# leave unset to skip cross-app revalidation. ≥ 16 chars.
# Generate with `openssl rand -base64 32`. Validated via @repo/env/revalidate.
REVALIDATE_SECRET=

# Optional — public web URL. When set, admin mutations POST to
# `${NEXT_PUBLIC_WEB_URL}/api/revalidate` so the public caches refresh.
NEXT_PUBLIC_WEB_URL=http://localhost:3000

# Optional — Sentry error reporting. Unset = no-op (zero runtime cost).
NEXT_PUBLIC_SENTRY_DSN=

# Optional — Cloudflare R2 / S3-compatible object storage (@repo/storage).
# Only needed if your project stores files. Set all five to enable uploads.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=
NEXT_PUBLIC_R2_PUBLIC_URL=
