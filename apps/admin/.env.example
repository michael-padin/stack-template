# Admin-only overrides (port 3001). Shared vars (DB, auth secret, app name,
# flags…) come from the root .env.example → root .env.local. Copy this to
# apps/admin/.env.local.

# Canonical URL of THIS app — used for OAuth callbacks. Differs per app, so it
# can't live in the shared root file. Validated via @repo/env/auth.
BETTER_AUTH_URL=http://localhost:3001
